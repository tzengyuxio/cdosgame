---
import '../styles/global.css';
import { withBase } from '../lib/links.js';
const { title = '中文 DOS 遊戲資料庫' } = Astro.props;
---
<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href={withBase('/')} class="brand">中文 DOS 遊戲資料庫</a>
        <nav><a href={withBase('/games')}>目錄</a><a href={withBase('/companies')}>廠商</a><a href={withBase('/series')}>系列</a><a href={withBase('/genres')}>類型</a><a href={withBase('/about')}>關於</a></nav>
      </div>
    </header>
    <main><slot /></main>
  </body>
</html>
