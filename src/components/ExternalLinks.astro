---
import { fandomUrl } from '../lib/links.js';
import RefSection from './RefSection.astro';
const { g } = Astro.props;
const r = g.references || {};
// 參考資料 (References): the catalog's cited source pages.
const refItems = [];
if (r.chiuinan) refItems.push({ text: '青衫之友 介紹頁', url: r.chiuinan });
if (r.fandom) refItems.push({ text: 'Fandom 條目', url: fandomUrl(r.fandom) });
if (r.omega) refItems.push({ text: 'Omega 討論串', url: r.omega });
// 外部連結 (External Links): related, non-citation links.
const extItems = Object.entries(g.external_links || {}).map(([text, url]) => ({ text, url }));
---
<RefSection heading="參考資料" items={refItems} ordered />
<RefSection heading="外部連結" items={extItems} />
