---
// Generic 參考資料 / 外部連結 section. items: [{ text, url }]. ordered → <ol> (cited
// references), else <ul> (related links). Renders nothing when empty.
const { heading, items = [], ordered = false } = Astro.props;
const list = (items || []).filter(it => it && it.url);
const Tag = ordered ? 'ol' : 'ul';
---
{list.length > 0 && (
  <section class="sources">
    <h2>{heading}</h2>
    <Tag class="refs">
      {list.map(it => (
        <li><a class="lk" href={it.url} target="_blank" rel="noopener nofollow">{it.text || it.url} ↗</a></li>
      ))}
    </Tag>
  </section>
)}
