---
// Unified citation footer for all entity types (see docs/refs-convention.md).
// Three sections: 參考資料 (references) / 註釋 (footnotes) / 外部連結 (external links).
// Single continuous [N] sequence (wikipedia-style, by prose appearance order):
// cited refs [1..k] (carry #cite-N anchors), then general references [k+1..k+m]
// (numbered too, for a consistent all-numbered 參考資料 list, but no inline anchor),
// then footnotes [k+m+1..]. External links are an unnumbered list.
const { footnotes = [], citedRefs = [], generalRefs = [], externalLinks = [] } = Astro.props;
const k = citedRefs.length;
const m = generalRefs.length;
---
{(citedRefs.length > 0 || generalRefs.length > 0) && (
  <section class="sources">
    <h2>參考資料</h2>
    <ol class="refs">
      {citedRefs.map((it, i) => (
        <li id={`cite-${i + 1}`} value={i + 1}>
          <a class="lk" href={it.url} target="_blank" rel="noopener nofollow">{it.text || it.url} ↗</a>
        </li>
      ))}
      {generalRefs.map((it, j) => (
        <li value={k + j + 1}>
          <a class="lk" href={it.url} target="_blank" rel="noopener nofollow">{it.text || it.url} ↗</a>
        </li>
      ))}
    </ol>
  </section>
)}
{footnotes.length > 0 && (
  <section class="sources">
    <h2>註釋</h2>
    <ol class="refs">
      {footnotes.map((text, i) => <li id={`cite-${k + m + i + 1}`} value={k + m + i + 1}>{text}</li>)}
    </ol>
  </section>
)}
{externalLinks.length > 0 && (
  <section class="sources">
    <h2>外部連結</h2>
    <ul class="refs">
      {externalLinks.map(it => (
        <li><a class="lk" href={it.url} target="_blank" rel="noopener nofollow">{it.text || it.url} ↗</a></li>
      ))}
    </ul>
  </section>
)}
