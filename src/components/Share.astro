---
// Social share box: X / Facebook / copy-URL with inline SVG icons (no font
// dependency). Share targets resolve client-side from the live location.
---
<div class="share">
  <span class="share-title">分享</span>
  <div class="share-row">
    <a class="share-btn" data-share="x" target="_blank" rel="noopener" href="#" aria-label="分享到 X" title="分享到 X">
      <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path fill="currentColor" d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
    </a>
    <a class="share-btn" data-share="fb" target="_blank" rel="noopener" href="#" aria-label="分享到 Facebook" title="分享到 Facebook">
      <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path fill="currentColor" d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
    </a>
    <button class="share-btn share-copy" type="button" data-share="copy" title="複製網址">
      <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path fill="currentColor" d="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z"/></svg>
      <span class="lbl">複製網址</span>
    </button>
  </div>
</div>
<script is:inline>
  document.querySelectorAll('.share').forEach((box) => {
    const url = location.href, title = document.title;
    const fb = box.querySelector('[data-share="fb"]');
    const x = box.querySelector('[data-share="x"]');
    const copy = box.querySelector('[data-share="copy"]');
    if (fb) fb.href = 'https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent(url);
    if (x) x.href = 'https://twitter.com/intent/tweet?url=' + encodeURIComponent(url) + '&text=' + encodeURIComponent(title);
    if (copy) copy.addEventListener('click', async () => {
      const lbl = copy.querySelector('.lbl');
      try {
        await navigator.clipboard.writeText(url);
        if (lbl) { const old = lbl.textContent; lbl.textContent = '已複製！'; setTimeout(() => { lbl.textContent = old; }, 1500); }
      } catch (e) { /* clipboard blocked */ }
    });
  });
</script>
