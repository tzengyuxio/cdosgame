---
import { gameUrl } from '../lib/links.js';
import { genreLabel } from '../lib/labels.js';
const { games } = Astro.props;
---
<ul class="results">
  {games.map(g => (
    <li><a href={gameUrl(g.id)}>
      <span class="r-title">{g.title_zh}</span>
      <span class="r-meta">{g.year ?? '—'} · {g.developer || g.publisher_tw?.[0] || '—'} · {genreLabel(g.genre) || '—'}</span>
    </a></li>
  ))}
</ul>
