---
import { getCollection, getEntry, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import DosBar from '../../components/DosBar.astro';
import { seriesUrl, companyUrl, teamUrl, gameUrl, personUrl, topicUrl, withBase } from '../../lib/links.js';
import { organizationJsonLd, breadcrumb } from '../../lib/jsonld.js';
import { lastModified } from '../../lib/gitdates.js';
import EntityRefs from '../../components/EntityRefs.astro';
import Share from '../../components/Share.astro';
import Gallery from '../../components/Gallery.astro';
import Lightbox from '../../components/Lightbox.astro';
import { coverOf, decorate, galleryGroups, kindLabel } from '../../lib/media.js';

export async function getStaticPaths() {
  const games = await getCollection('games', e => import.meta.env.PROD ? e.data.published : true);
  const map = new Map();
  const get = n => { if (!map.has(n)) map.set(n, { developed: [], published: [] }); return map.get(n); };
  for (const e of games) {
    const g = e.data;
    if (g.developer) get(g.developer).developed.push(g);
    for (const p of (g.publisher_tw || [])) if (p !== g.developer) get(p).published.push(g);
  }
  // route set = vendors of (published) games ∪ company md whose published gate is on
  const showAll = !import.meta.env.PROD;
  for (const e of await getCollection('companies')) {
    if ((showAll || e.data.published) && !map.has(e.id)) map.set(e.id, { developed: [], published: [] });
  }
  const byYear = (a, b) => (a.year ?? 9999) - (b.year ?? 9999);
  return [...map].map(([name, v]) => ({
    params: { name },
    props: { developed: v.developed.sort(byYear), published: v.published.sort(byYear) },
  }));
}
const { name } = Astro.params;
const { developed, published } = Astro.props;
const company = await getEntry('companies', name);
const c = company?.data;
const companyIds = new Set((await getCollection('companies')).map(e => e.id));
const personIds = new Set((await getCollection('people')).map(e => e.id));
// in-house teams whose parent_company points at this company
const teams = (await getCollection('teams')).filter(t => t.data.parent_company === name);
// curated topics whose parent points at this company
const topics = (await getCollection('topics'))
  .filter(t => (import.meta.env.PROD ? t.data.published : true)
    && t.data.parent_type === 'company'
    && (t.data.parent === name || t.data.parent === c?.name_zh));
const Body = company ? (await render(company)).Content : null;
const featured = (c?.featured_games || [])
  .map(id => [...developed, ...published].find(g => g.id === id)).filter(Boolean);
const STATUS = { active: '營運中', defunct: '已歇業', acquired: '被併購', merged: '已合併', renamed: '已更名' };
const ROLE = { developer: '開發', publisher: '發行', localizer: '中文化', distributor: '代理' };
const lifespan = c?.founded ? (c.dissolved ? `${c.founded}–${c.dissolved}` : `${c.founded}`) : null;
const roles = (c?.roles || []).map(r => ROLE[r] || r);
const desc = `${c?.name_zh || name}${c?.name_en ? `（${c.name_en}）` : ''}：開發 ${developed.length} 款、台灣發行／代理 ${published.length} 款。中文 DOS 遊戲資料庫廠商條目。`;
const media = c?.media || [];
const cover = coverOf(media);
const coverItem = cover ? decorate(cover, 'companies', name) : null;
const mediaGroups = galleryGroups(media, 'companies', name);
const ogImage = cover ? `/media/companies/${name}/${cover.src}` : undefined;
const site = (Astro.site?.href || 'https://tzengyuxio.github.io/').replace(/\/$/, '');
const canonical = site + Astro.url.pathname;
const sameAs = [...(c?.references || []).map(r => r.url), ...Object.values(c?.external_links || {})];
const jsonLd = [
  organizationJsonLd(c, name, { site, url: canonical, sameAs, dateModified: lastModified(`content/companies/${name}.md`) }),
  breadcrumb(site, [
    { name: '中文 DOS 遊戲資料庫', url: site + withBase('/') },
    { name: '廠商', url: site + withBase('/companies') },
    { name: c?.name_zh || name, url: canonical },
  ]),
];
---
<Base title={`${c?.name_zh || name}｜中文 DOS 遊戲資料庫`} description={desc} ogType="article" ogImage={ogImage} jsonLd={jsonLd}>
  <DosBar path={`COMPANIES\\${name}`} right={c?.name_en || ''} />
  <div class="game-wiki">
    <div class="gw-main">
      <h1 class="game-title">{c?.name_zh || name}</h1>
      <div class="entity-sub">{c?.name_en && `${c.name_en} · `}開發 {developed.length} · 台灣代理 {published.length}</div>
      {Body && <div class="prose"><Body /></div>}
      {(c?.featured_series || []).length > 0 && (
        <><h2>代表系列</h2><div class="vendrow">{c.featured_series.map(s => <a class="vend" href={seriesUrl(s)}>{s}</a>)}</div></>
      )}
      {featured.length > 0 && (
        <><h2>代表作</h2><div class="cardrow">{featured.map(g => (
          <div class="scard"><div class="t"><a class="lk" href={gameUrl(g.id)}>{g.title_zh}</a></div><div class="m">{g.year ?? ''}</div></div>
        ))}</div></>
      )}
      {teams.length > 0 && (
        <><h2>旗下團隊</h2><div class="vendrow">{teams.map(t => <a class="vend" href={teamUrl(t.id)}>{t.data.name_zh || t.id}</a>)}</div></>
      )}
      {topics.length > 0 && (
        <><h2>專題／延伸條目</h2><ul class="glist">{topics.map(t => <li><a class="lk" href={topicUrl(t.id)}>{t.data.name_zh || t.id}</a></li>)}</ul></>
      )}
      {developed.length > 0 && <><h2>開發作品（{developed.length}）</h2><ul class="glist">{developed.map(g => <li><span class="y">{g.year ?? '—'}</span><a class="lk" href={gameUrl(g.id)}>{g.title_zh}</a></li>)}</ul></>}
      {published.length > 0 && <><h2>台灣發行／代理（{published.length}）</h2><ul class="glist">{published.map(g => <li><span class="y">{g.year ?? '—'}</span><a class="lk" href={gameUrl(g.id)}>{g.title_zh}</a></li>)}</ul></>}
      <EntityRefs entity={c} />
      <Gallery groups={mediaGroups} />
    </div>
    <aside class="gw-ib">
      {coverItem && (
        <figure class="cover-fig">
          <button class="cover-img" type="button" data-full={coverItem.full} data-caption={coverItem.caption || ''} data-source={coverItem.src_obj.name} data-source-url={coverItem.src_obj.url || ''} data-credit={coverItem.credit || ''}>
            <img src={coverItem.full} alt={coverItem.caption || c?.name_zh || name} />
          </button>
          <figcaption>{coverItem.caption || kindLabel(coverItem.kind)}</figcaption>
        </figure>
      )}
      <div class="infobox-wrap">
        <table class="infobox">
          {c?.name_en && <tr><th>英文名</th><td>{c.name_en}</td></tr>}
          {lifespan && <tr><th>{c.dissolved ? '存續' : '成立'}</th><td>{lifespan}</td></tr>}
          {c?.status && <tr><th>狀態</th><td>{STATUS[c.status] || c.status}</td></tr>}
          {(c?.predecessor || []).length > 0 && <tr><th>前身</th><td>{c.predecessor.map((p, i) => <>{i > 0 && '、'}{companyIds.has(p) ? <a class="lk" href={companyUrl(p)}>{p}</a> : p}</>)}</td></tr>}
          {c?.successor && <tr><th>後繼</th><td>{companyIds.has(c.successor) ? <a class="lk" href={companyUrl(c.successor)}>{c.successor}</a> : c.successor}</td></tr>}
          {c?.region && <tr><th>地區</th><td>{c.region}</td></tr>}
          {c?.hq && <tr><th>總部</th><td>{c.hq}</td></tr>}
          {(c?.founder || []).length > 0 && <tr><th>創辦人</th><td>{c.founder.map((p, i) => <>{i > 0 && '、'}{personIds.has(p) ? <a class="lk" href={personUrl(p)}>{p}</a> : p}</>)}</td></tr>}
          {roles.length > 0 && <tr><th>角色</th><td>{roles.join('、')}</td></tr>}
          <tr><th>作品數</th><td>開發 {developed.length} · 代理 {published.length}</td></tr>
          {c?.website && <tr><th>官網</th><td><a class="lk" href={c.website} target="_blank" rel="noopener nofollow">官方網站 ↗</a></td></tr>}
        </table>
      </div>
      <Share />
    </aside>
  </div>
  {media.length > 0 && <Lightbox />}
</Base>
