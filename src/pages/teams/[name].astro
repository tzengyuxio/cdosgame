---
import { getCollection, getEntry, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import DosBar from '../../components/DosBar.astro';
import { companyUrl, personUrl } from '../../lib/links.js';
import RefSection from '../../components/RefSection.astro';

export async function getStaticPaths() {
  const games = await getCollection('games', e => import.meta.env.PROD ? e.data.published : true);
  // route set = dev_team values aggregated from games ∪ authored team md files
  const map = new Map();
  for (const e of games) {
    const t = e.data.dev_team;
    if (!t) continue;
    if (!map.has(t)) map.set(t, []);
    map.get(t).push(e.data);
  }
  const files = await getCollection('teams');
  const names = new Set([...map.keys(), ...files.map(e => e.id)]);
  const byYear = (a, b) => (a.year ?? 9999) - (b.year ?? 9999);
  return [...names].map(name => ({
    params: { name },
    props: { developed: (map.get(name) || []).sort(byYear) },
  }));
}
const { name } = Astro.params;
const { developed } = Astro.props;
const team = await getEntry('teams', name);
const c = team?.data;
const companyIds = new Set((await getCollection('companies')).map(e => e.id));
const personIds = new Set((await getCollection('people')).map(e => e.id));
const Body = team ? (await render(team)).Content : null;
const featured = (c?.featured_games || []).map(id => developed.find(g => g.id === id)).filter(Boolean);
const STATUS = { active: '運作中', defunct: '已解散', merged: '已合併', renamed: '已更名' };
const lifespan = c?.founded ? (c.dissolved ? `${c.founded}–${c.dissolved}` : `${c.founded}`) : null;
const hostOf = u => { try { return new URL(u).hostname.replace(/^www\./, ''); } catch { return u; } };
const refItems = (c?.references || []).map(s => ({ text: s.title || hostOf(s.url), url: s.url }));
---
<Base title={`${c?.name_zh || name}｜中文 DOS 遊戲資料庫`}>
  <DosBar path={`TEAMS\\${name}`} right={c?.name_en || ''} />
  <div class="game-wiki">
    <div class="gw-main">
      <h1 class="game-title">{c?.name_zh || name}</h1>
      <div class="entity-sub">
        {c?.parent_company && <>所屬 <a class="lk" href={companyUrl(c.parent_company)}>{c.parent_company}</a> · </>}
        開發 {developed.length}
      </div>
      {Body && <div class="prose"><Body /></div>}
      {featured.length > 0 && (
        <><h2>代表作</h2><div class="cardrow">{featured.map(g => (
          <div class="scard"><div class="t"><a class="lk" href={`/games/${g.id}`}>{g.title_zh}</a></div><div class="m">{g.year ?? ''}</div></div>
        ))}</div></>
      )}
      {developed.length > 0 && <><h2>開發作品（{developed.length}）</h2><ul class="glist">{developed.map(g => <li><span class="y">{g.year ?? '—'}</span><a class="lk" href={`/games/${g.id}`}>{g.title_zh}</a></li>)}</ul></>}
      <RefSection heading="參考資料" items={refItems} ordered />
    </div>
    <aside class="gw-ib">
      <div class="infobox-wrap">
        <table class="infobox">
          {c?.name_en && <tr><th>英文名</th><td>{c.name_en}</td></tr>}
          {c?.parent_company && <tr><th>所屬公司</th><td><a class="lk" href={companyUrl(c.parent_company)}>{c.parent_company}</a></td></tr>}
          {lifespan && <tr><th>{c.dissolved ? '存續' : '成立'}</th><td>{lifespan}</td></tr>}
          {c?.status && <tr><th>狀態</th><td>{STATUS[c.status] || c.status}</td></tr>}
          {(c?.members || []).length > 0 && <tr><th>主要成員</th><td>{c.members.map((p, i) => <>{i > 0 && '、'}{personIds.has(p) ? <a class="lk" href={personUrl(p)}>{p}</a> : p}</>)}</td></tr>}
          <tr><th>作品數</th><td>{developed.length}</td></tr>
        </table>
      </div>
    </aside>
  </div>
</Base>
