---
import { getCollection, getEntry, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import DosBar from '../../components/DosBar.astro';
import { companyUrl, teamUrl, gameUrl, withBase } from '../../lib/links.js';
import { personJsonLd, breadcrumb } from '../../lib/jsonld.js';
import { lastModified } from '../../lib/gitdates.js';
import EntityRefs from '../../components/EntityRefs.astro';
import Share from '../../components/Share.astro';
import Gallery from '../../components/Gallery.astro';
import Lightbox from '../../components/Lightbox.astro';
import { coverOf, decorate, galleryGroups, kindLabel } from '../../lib/media.js';

export async function getStaticPaths() {
  const games = await getCollection('games', e => import.meta.env.PROD ? e.data.published : true);
  // credit a person by staff[].person (canonical slug) when set, else staff[].name
  const credits = new Map();  // personKey -> Map(gameId -> {game, roles:Set})
  for (const e of games) {
    for (const s of (e.data.staff || [])) {
      const key = s.person || s.name;
      if (!credits.has(key)) credits.set(key, new Map());
      const m = credits.get(key);
      if (!m.has(e.data.id)) m.set(e.data.id, { game: e.data, roles: new Set() });
      if (s.role) m.get(e.data.id).roles.add(s.role);
    }
  }
  const files = await getCollection('people');
  const gameById = new Map(games.map(e => [e.data.id, e.data]));
  // route set = credited names (in published games) ∪ people md whose published gate is on
  const showAll = !import.meta.env.PROD;
  const names = new Set([...credits.keys(), ...files.filter(e => showAll || e.data.published).map(e => e.id)]);
  const byYear = (a, b) => (a.game.year ?? 9999) - (b.game.year ?? 9999);
  return [...names].map(name => {
    const m = credits.get(name) || new Map();
    const creditList = [...m.values()]
      .map(x => ({ game: x.game, roles: [...x.roles] })).sort(byYear);
    const entry = files.find(e => e.id === name);
    const creditIds = new Set(creditList.map(x => x.game.id));
    // 相關作品 = featured games NOT already shown as a staff credit (代言/客串/未列名參與)
    const featured = (entry?.data.featured_games || [])
      .map(id => gameById.get(id)).filter(Boolean).filter(g => !creditIds.has(g.id));
    return { params: { name }, props: { credits: creditList, featured } };
  });
}
const { name } = Astro.params;
const { credits, featured } = Astro.props;
const person = await getEntry('people', name);
const c = person?.data;
const companyIds = new Set((await getCollection('companies')).map(e => e.id));
const teamIds = new Set((await getCollection('teams')).map(e => e.id));
const Body = person ? (await render(person)).Content : null;
const affLink = a => companyIds.has(a) ? companyUrl(a) : (teamIds.has(a) ? teamUrl(a) : null);
const desc = [c?.name_zh || name, (c?.roles || []).join('、'), (c?.affiliations || []).join('、')]
  .filter(Boolean).join('｜') + (credits.length ? ` · 參與 ${credits.length} 款遊戲` : '') + '。中文 DOS 遊戲資料庫人物條目。';
const site = (Astro.site?.href || 'https://tzengyuxio.github.io/').replace(/\/$/, '');
const canonical = site + Astro.url.pathname;
const sameAs = [...(c?.references || []).map(r => r.url), ...Object.values(c?.external_links || {})];
const media = c?.media || [];
const cover = coverOf(media);
const coverItem = cover ? decorate(cover, 'people', name) : null;
const mediaGroups = galleryGroups(media, 'people', name);
const ogImage = cover ? `/media/people/${name}/${cover.src}` : undefined;
const jsonLd = [
  personJsonLd(c, name, { url: canonical, sameAs, dateModified: lastModified(`content/people/${name}.md`) }),
  breadcrumb(site, [
    { name: '中文 DOS 遊戲資料庫', url: site + withBase('/') },
    { name: '人物', url: site + withBase('/people') },
    { name: c?.name_zh || name, url: canonical },
  ]),
];
---
<Base title={`${c?.name_zh || name}｜中文 DOS 遊戲資料庫`} description={desc} ogType="profile" ogImage={ogImage} jsonLd={jsonLd}>
  <DosBar path={`PEOPLE\\${name}`} right={c?.name_en || ''} />
  <div class="game-wiki">
    <div class="gw-main">
      <h1 class="game-title">{c?.name_zh || name}</h1>
      <div class="entity-sub">{[...(c?.roles || [])].join('、')}{(c?.roles || []).length > 0 && credits.length > 0 && ' · '}{credits.length > 0 && `參與 ${credits.length} 款`}</div>
      {Body && <div class="prose"><Body /></div>}
      {credits.length > 0 && (
        <><h2>參與作品（{credits.length}）</h2>
        <ul class="glist">{credits.map(({ game, roles }) => (
          <li><span class="y">{game.year ?? '—'}</span><a class="lk" href={gameUrl(game.id)}>{game.title_zh}</a>{roles.length > 0 && <span class="role-tag"> · {roles.join('、')}</span>}</li>
        ))}</ul></>
      )}
      {featured.length > 0 && (
        <><h2>相關作品</h2>
        <ul class="glist">{featured.map(g => <li><span class="y">{g.year ?? '—'}</span><a class="lk" href={gameUrl(g.id)}>{g.title_zh}</a></li>)}</ul></>
      )}
      <EntityRefs entity={c} />
      <Gallery groups={mediaGroups} />
    </div>
    <aside class="gw-ib">
      {coverItem && (
        <figure class="cover-fig">
          <button class="cover-img" type="button" data-full={coverItem.full} data-caption={coverItem.caption || ''} data-source={coverItem.src_obj.name} data-source-url={coverItem.src_obj.url || ''} data-credit={coverItem.credit || ''}>
            <img src={coverItem.full} alt={coverItem.caption || c?.name_zh || name} />
          </button>
          <figcaption>{coverItem.caption || kindLabel(coverItem.kind)}</figcaption>
        </figure>
      )}
      <div class="infobox-wrap">
        <table class="infobox">
          {c?.name_en && <tr><th>英文名</th><td>{c.name_en}</td></tr>}
          {(c?.aliases || []).length > 0 && <tr><th>別名</th><td>{c.aliases.join('、')}</td></tr>}
          {c?.born && <tr><th>出生</th><td>{c.born}</td></tr>}
          {(c?.roles || []).length > 0 && <tr><th>角色</th><td>{c.roles.join('、')}</td></tr>}
          {(c?.affiliations || []).length > 0 && <tr><th>經歷</th><td>{c.affiliations.map((a, i) => { const u = affLink(a); return <>{i > 0 && '、'}{u ? <a class="lk" href={u}>{a}</a> : a}</>; })}</td></tr>}
          {credits.length > 0 && <tr><th>參與作品</th><td>{credits.length}</td></tr>}
        </table>
      </div>
      <Share />
    </aside>
  </div>
  {media.length > 0 && <Lightbox />}
</Base>
