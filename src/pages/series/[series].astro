---
import { getCollection, getEntry, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import GameList from '../../components/GameList.astro';
import { groupBy, topValue, yearRange } from '../../lib/gamesQuery.js';
import { companyUrl, topicUrl, withBase } from '../../lib/links.js';
import { seriesJsonLd, breadcrumb } from '../../lib/jsonld.js';
import { lastModified } from '../../lib/gitdates.js';
import Share from '../../components/Share.astro';

export async function getStaticPaths() {
  const games = await getCollection('games', e => import.meta.env.PROD ? e.data.published : true);
  const by = groupBy(games.map(e => e.data), g => g.series);
  // route set = series of (published) games ∪ series md whose published gate is on
  const showAll = !import.meta.env.PROD;
  const names = new Set(by.keys());
  for (const e of await getCollection('series')) if (showAll || e.data.published) names.add(e.id);
  return [...names].map(series => ({ params: { series }, props: { list: by.get(series) || [] } }));
}
const { series } = Astro.params;
const { list } = Astro.props;
const games = [...list].sort((a, b) => (a.year ?? 9999) - (b.year ?? 9999));
const dev = topValue(list, g => g.developer);
const range = yearRange(list);
const entry = await getEntry('series', series);
const Body = entry ? (await render(entry)).Content : null;
// curated topics whose parent points at this series
const topics = (await getCollection('topics'))
  .filter(t => (import.meta.env.PROD ? t.data.published : true)
    && t.data.parent_type === 'series'
    && t.data.parent === series);
const desc = `${series}系列：收錄 ${games.length} 款${dev ? `，主要廠商 ${dev}` : ''}${range ? `（${range.min}–${range.max}）` : ''}。中文 DOS 遊戲資料庫系列條目。`;
const site = (Astro.site?.href || 'https://tzengyuxio.github.io/').replace(/\/$/, '');
const canonical = site + Astro.url.pathname;
const jsonLd = [
  seriesJsonLd(series, { url: canonical, description: desc, dev, dateModified: lastModified(`content/series/${series}.md`) }),
  breadcrumb(site, [
    { name: '中文 DOS 遊戲資料庫', url: site + withBase('/') },
    { name: '系列', url: site + withBase('/series') },
    { name: `${series}系列`, url: canonical },
  ]),
];
---
<Base title={`${series}系列｜中文 DOS 遊戲資料庫`} description={desc} ogType="article" jsonLd={jsonLd}>
  <h1 class="hub-title">{series}系列 <span class="hub-count">{games.length} 款</span></h1>
  <div class="entity-sub">{dev && <>主要廠商 <a class="lk" href={companyUrl(dev)}>{dev}</a> · </>}{range && `${range.min}–${range.max}`}</div>
  {Body && <div class="prose"><Body /></div>}
  <GameList games={games} />
  {topics.length > 0 && (
    <><h2>專題／延伸條目</h2><ul class="glist">{topics.map(t => <li><a class="lk" href={topicUrl(t.id)}>{t.data.name_zh || t.id}</a></li>)}</ul></>
  )}
  <Share />
</Base>
