---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { topicUrl, companyUrl, seriesUrl, teamUrl, personUrl } from '../../lib/links.js';

const showAll = !import.meta.env.PROD;
// stroke-aware ordering: Latin/digits alphabetical, 漢字 by stroke (same as 廠商索引)
let coll;
try { coll = new Intl.Collator('zh-Hant-u-co-stroke', { numeric: true }); }
catch { coll = new Intl.Collator('zh-Hant'); }
const topics = (await getCollection('topics', e => showAll || e.data.published))
  .sort((a, b) => coll.compare(a.data.name_zh, b.data.name_zh));
const PT = { company: companyUrl, series: seriesUrl, team: teamUrl, person: personUrl };
---
<Base title="專題｜中文 DOS 遊戲資料庫">
  <h1 class="hub-title">專題 <span class="hub-count">{topics.length} 篇</span></h1>
  <p class="hub-legend">附屬於公司、系列等實體的策展長文與目錄。</p>
  <ul class="glist">
    {topics.map(e => (
      <li>
        <a class="lk" href={topicUrl(e.id)}>{e.data.name_zh}</a>
        {e.data.parent && <span class="y">（{e.data.parent}）</span>}
      </li>
    ))}
  </ul>
</Base>
