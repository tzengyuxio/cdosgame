---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import DosBar from '../../components/DosBar.astro';
import Infobox from '../../components/Infobox.astro';
import ExternalLinks from '../../components/ExternalLinks.astro';
import RelatedGames from '../../components/RelatedGames.astro';
import CategoryFooter from '../../components/CategoryFooter.astro';
import Share from '../../components/Share.astro';
import Gallery from '../../components/Gallery.astro';
import Lightbox from '../../components/Lightbox.astro';
import { coverOf, decorate, coverFigcaption, groupDecorated } from '../../lib/media.js';
import { genreUrl, seriesUrl, personUrl, topicUrl, withBase } from '../../lib/links.js';
import { gameJsonLd, breadcrumb } from '../../lib/jsonld.js';
import { lastModified } from '../../lib/gitdates.js';
import { locLabel, genreLabel } from '../../lib/labels.js';
import { relatedFor } from '../../lib/gamesQuery.js';

export async function getStaticPaths() {
  // max items shown per "related games" block (同系列／同廠商／同年）.
  // Declared inside getStaticPaths: Astro runs it before the rest of the
  // frontmatter, so a module-level const would still be in the TDZ here.
  const RELATED_LIMIT = 6;
  const games = await getCollection('games', e => import.meta.env.PROD ? e.data.published : true);
  const all = games.map(e => e.data);
  // compute related here (pass only the small result) — never pass the full
  // `all` array as props (4144 pages × 4144 games would explode the build).
  return games.map(e => ({ params: { id: e.data.id }, props: { entry: e, related: relatedFor(e.data, all, RELATED_LIMIT) } }));
}

const { entry, related } = Astro.props;
const g = entry.data;
const { Content } = await render(entry);
const hasBody = (entry.body || '').trim().length > 0;
// SEO description: first sentences of the body, else a fact-built fallback.
const plain = (entry.body || '')
  .replace(/<[^>]+>/g, '').replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
  .replace(/[#>*`_]/g, '').replace(/\s+/g, ' ').trim();
const facts = [g.year && `${g.year}`, g.developer, genreLabel(g.genre), g.localization_level && locLabel(g.localization_level)].filter(Boolean).join(' · ');
const description = (plain ? plain.slice(0, 140) : `《${g.title_zh}》${facts ? `（${facts}）` : ''}——中文 DOS 遊戲資料庫的考據條目。`);
const site = (Astro.site?.href || 'https://tzengyuxio.github.io/').replace(/\/$/, '');
const canonical = site + Astro.url.pathname;
// curated media: infobox cover, category gallery, per-page og:image
const cover = coverOf(g.media);
const coverItem = cover ? decorate(cover, 'games', g.id) : null;
// publisher/company ads that feature this game (stored once on the company,
// surfaced here via media[].games — e.g. one 第三波 ad covering several 光榮 titles)
const companies = await getCollection('companies', e => import.meta.env.PROD ? e.data.published : true);
const adItems = [];
for (const c of companies) for (const m of (c.data.media || [])) if (m.games?.includes(g.id)) adItems.push(decorate(m, 'companies', c.id));
const groups = groupDecorated([...g.media.map(m => decorate(m, 'games', g.id)), ...adItems]);
const hasMedia = g.media.length > 0 || adItems.length > 0;
const ogImage = cover ? `/media/games/${g.id}/${cover.src}` : undefined;
const jsonLd = [
  gameJsonLd(g, { site, url: canonical, description, dateModified: lastModified(`content/games/${g.id}.md`) }),
  breadcrumb(site, [
    { name: '中文 DOS 遊戲資料庫', url: site + withBase('/') },
    { name: '遊戲目錄', url: site + withBase('/games') },
    { name: g.title_zh, url: canonical },
  ]),
];
// 參見: auto-aggregation topics this game belongs to (e.g. 金庸改編遊戲), matched
// on the game's adaptation against the topic's list_games filters — same predicate
// the topic page uses to build its list, so membership stays consistent both ways.
const seeAlsoTopics = (await getCollection('topics', e => import.meta.env.PROD ? e.data.published : true))
  .filter(t => {
    const q = t.data.list_games;
    return q && g.adaptation
      && (!q.adaptation_author || g.adaptation.author === q.adaptation_author)
      && (!q.adaptation_title || g.adaptation.title === q.adaptation_title)
      && (!q.adaptation_medium || g.adaptation.medium === q.adaptation_medium);
  });
// link a staff credit to /people when a person page exists (by staff.person slug or name)
const personIds = new Set((await getCollection('people')).map(e => e.id));
const staffSlug = s => s.person || s.name;
// group staff credits by role (preserving first-seen order) so a role with
// several people renders as one line instead of repeating the role label.
const staffByRole = staff => {
  const groups = [];
  for (const s of staff) {
    let grp = groups.find(x => x.role === s.role);
    if (!grp) { grp = { role: s.role, people: [] }; groups.push(grp); }
    grp.people.push(s);
  }
  return groups;
};
---
<Base title={`${g.title_zh}｜中文 DOS 遊戲資料庫`} description={description} ogType="article" ogImage={ogImage} jsonLd={jsonLd}>
  <DosBar path={g.title_zh} right={g.id} />
  <div class="game-wiki">
    <div class="gw-main">
      <h1 class="game-title">{g.title_zh}{g.year && <span class="year">({g.year})</span>}</h1>
      <div class="chips">
        {g.genre && <a class="chip chip-genre" href={genreUrl(g.genre)}>{genreLabel(g.genre)}</a>}
        {g.series && <a class="chip" href={seriesUrl(g.series)}>{g.series}系列</a>}
        {g.localization_level && <span class="chip">{locLabel(g.localization_level)}</span>}
        {g.adult && <span class="chip chip-adult">18禁</span>}
      </div>
      <section class="prose">
        {hasBody ? <Content /> : <p class="muted">簡介待補</p>}
      </section>
      {(g.staff || []).length > 0 && (
        <section class="staff">
          <h2>製作人員</h2>
          <ul class="stafflist">
            {staffByRole(g.staff).map(grp => (
              <li>
                <span class="role">{grp.role}</span>
                <span class="who">{grp.people.map((s, i) => <>{i > 0 && '、'}{personIds.has(staffSlug(s)) ? <a class="lk" href={personUrl(staffSlug(s))}>{s.name}</a> : s.name}</>)}</span>
              </li>
            ))}
          </ul>
        </section>
      )}
      <RelatedGames related={related} g={g} />
      {seeAlsoTopics.length > 0 && (
        <section class="rel-block">
          <h2>參見</h2>
          <ul class="see-also">
            {seeAlsoTopics.map(t => <li><a class="lk" href={topicUrl(t.id)}>{t.data.name_zh || t.id}</a></li>)}
          </ul>
        </section>
      )}
      <Gallery groups={groups} />
      <ExternalLinks g={g} />
    </div>
    <aside class="gw-ib">
      {coverItem ? (
        <figure class="cover-fig">
          <button
            class="cover-img" type="button"
            data-full={coverItem.full}
            data-caption={coverFigcaption(coverItem)}
            data-source={coverItem.src_obj.name}
            data-source-url={coverItem.src_obj.url || ''}
            data-credit={coverItem.credit || ''}
          >
            <img src={coverItem.full} alt={coverItem.caption || g.title_zh} />
          </button>
          <figcaption>{coverFigcaption(coverItem)}</figcaption>
        </figure>
      ) : (
        <div class="cover-placeholder">封面待補</div>
      )}
      <Infobox g={g} />
      <Share />
    </aside>
  </div>
  <CategoryFooter g={g} />
  {hasMedia && <Lightbox />}
</Base>
