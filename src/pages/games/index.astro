---
import Base from '../../layouts/Base.astro';
---
<Base title="目錄｜中文 DOS 遊戲資料庫">
  <div class="games-layout">
    <aside class="facets" id="facets"></aside>
    <div class="games-main">
      <div class="controls">
        <input id="search" type="search" placeholder="搜尋標題或別名…" />
        <select id="sort">
          <option value="year:asc">年份 ↑</option>
          <option value="year:desc">年份 ↓</option>
          <option value="title:asc">標題</option>
          <option value="vendor:asc">廠商</option>
        </select>
      </div>
      <div id="count" class="count"></div>
      <ul id="results" class="results"></ul>
      <div id="pager" class="pager"></div>
    </div>
  </div>

  <script>
    import { searchGames, applyFacets, sortGames, paginate, deriveFacets, NONE } from '../../lib/gamesQuery.js';
    import { locLabel, genreLabel } from '../../lib/labels.js';

    const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
    // Panel order is utility-first: 在地化 (the project's defining axis) on top,
    // then 類型, 年代, and the long 廠商 list last.
    const FACETS = [['loc','在地化'],['genre','類型'],['decade','年代'],['vendor','廠商']];
    const TOP_FACET_COUNT = 10;
    let GAMES = [];
    let vendorFilter = '';
    const showFacetTail = { genre: false, vendor: false };
    const showDecade = {};   // decade value → expanded (逐年) state
    const state = { q:'', sel:{decade:[],genre:[],vendor:[],loc:[]}, sort:'year:asc', page:1 };

    const esc = s => (s ?? '').toString().replace(/[&<>]/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;'}[c]));

    function readURL(){
      const p = new URLSearchParams(location.search);
      state.q = p.get('q') || '';
      state.sort = p.get('sort') || 'year:asc';
      state.page = +(p.get('page') || 1);
      for (const [f] of FACETS) { const v = p.get(f); state.sel[f] = v ? v.split('|') : []; }
    }
    function writeURL(){
      const p = new URLSearchParams();
      if (state.q) p.set('q', state.q);
      if (state.sort !== 'year:asc') p.set('sort', state.sort);
      if (state.page > 1) p.set('page', state.page);
      for (const [f] of FACETS) if (state.sel[f].length) p.set(f, state.sel[f].join('|'));
      const qs = p.toString();
      history.replaceState(null, '', location.pathname + (qs ? '?' + qs : ''));
    }

    function compute(){
      let r = searchGames(GAMES, state.q);
      r = applyFacets(r, state.sel);
      const [k, d] = state.sort.split(':');
      return sortGames(r, k, d);
    }

    function render(){
      const filtered = compute();
      const { items, total, pages, page } = paginate(filtered, state.page, 50);
      state.page = page;
      document.getElementById('count').textContent = `${total} 款`;
      document.getElementById('results').innerHTML = items.map(g => `
        <li><a href="${BASE}/games/${g.id}">
          <span class="r-title">${esc(g.title_zh)}</span>
          <span class="r-meta">${g.year ?? '—'} · ${esc(g.developer || g.publisher_tw[0] || '—')} · ${esc(genreLabel(g.genre) || '—')} · ${g.localization_level || '—'}</span>
        </a></li>`).join('');

      const pg = document.getElementById('pager');
      pg.innerHTML = '';
      if (pages > 1) {
        const prev = mkBtn('上一頁', page > 1, () => { state.page--; render(); });
        const next = mkBtn('下一頁', page < pages, () => { state.page++; render(); });
        const mid = document.createElement('span');
        mid.textContent = ` ${page} / ${pages} `;
        pg.append(prev, mid, next);
      }
      renderFacets();
      writeURL();
    }

    function mkBtn(label, enabled, fn){
      const b = document.createElement('button');
      b.textContent = label; b.disabled = !enabled; b.onclick = fn;
      return b;
    }

    function renderFacets(){
      const opts = deriveFacets(GAMES);
      const host = document.getElementById('facets');
      host.innerHTML = '';

      const addOpt = (sec, key, value, count) => {
        const checked = state.sel[key].includes(value);
        const text = key === 'loc' ? locLabel(value) : key === 'genre' ? genreLabel(value) : value;
        const lab = document.createElement('label');
        lab.innerHTML = `<input type="checkbox" ${checked ? 'checked' : ''}> ${esc(text)} <span class="c">${count}</span>`;
        lab.querySelector('input').onchange = e => {
          if (e.target.checked) state.sel[key].push(value);
          else state.sel[key] = state.sel[key].filter(v => v !== value);
          state.page = 1; render();
        };
        sec.append(lab);
      };
      const addMore = (sec, text, fn) => {
        const b = document.createElement('button');
        b.type = 'button'; b.className = 'facet-more'; b.textContent = text; b.onclick = fn;
        sec.append(b);
      };
      const addRankedFacet = (sec, key, items) => {
        const head = items.slice(0, TOP_FACET_COUNT);
        const tail = items.slice(TOP_FACET_COUNT);
        const selectedTail = tail.filter(o => state.sel[key].includes(o.value));
        const hiddenTail = tail.filter(o => !state.sel[key].includes(o.value));
        const toggleCount = showFacetTail[key] ? tail.length : hiddenTail.length;

        for (const o of head) addOpt(sec, key, o.value, o.count);
        for (const o of showFacetTail[key] ? tail : selectedTail) addOpt(sec, key, o.value, o.count);
        if (toggleCount) addMore(
          sec,
          showFacetTail[key] ? `收合並顯示前 ${TOP_FACET_COUNT} 項` : `顯示其餘 ${toggleCount} 項`,
          () => { showFacetTail[key] = !showFacetTail[key]; renderFacets(); },
        );
      };
      // 年代: two-level. Each decade is a selectable bucket; "逐年" expands it to
      // its individual years (same 'decade' facet key — a game matches its decade
      // or its year). A decade auto-expands when one of its years is selected.
      const addDecadeFacet = (sec, items) => {
        for (const dec of items) {
          if (dec.value === NONE) { addOpt(sec, 'decade', dec.value, dec.count); continue; }
          const expanded = showDecade[dec.value] || dec.years.some(y => state.sel.decade.includes(y.value));
          const row = document.createElement('div');
          row.className = 'facet-decade';
          addOpt(row, 'decade', dec.value, dec.count);
          if (dec.years.length > 1) {
            const tg = document.createElement('button');
            tg.type = 'button'; tg.className = 'facet-more facet-expand';
            tg.textContent = expanded ? '收合' : '逐年';
            tg.onclick = () => { showDecade[dec.value] = !expanded; renderFacets(); };
            row.append(tg);
          }
          sec.append(row);
          if (expanded) {
            const sub = document.createElement('div');
            sub.className = 'facet-years';
            for (const y of dec.years) addOpt(sub, 'decade', y.value, y.count);
            sec.append(sub);
          }
        }
      };

      for (const [key, label] of FACETS) {
        const sec = document.createElement('section');
        sec.className = 'facet';
        sec.innerHTML = `<h3>${label}</h3>`;

        if (key === 'genre') {
          addRankedFacet(sec, key, opts[key]);
          host.append(sec);
          continue;
        }

        if (key === 'decade') {
          addDecadeFacet(sec, opts.decade);
          host.append(sec);
          continue;
        }

        if (key !== 'vendor') {   // loc: fixed-order, show all
          for (const { value, count } of opts[key]) addOpt(sec, key, value, count);
          host.append(sec);
          continue;
        }

        // 廠商: case-insensitive 搜尋；無搜尋時只展開遊戲數量最多的前 10 家。
        const vf = document.createElement('input');
        vf.className = 'vfilter'; vf.placeholder = '篩廠商…'; vf.value = vendorFilter;
        vf.oninput = e => { vendorFilter = e.target.value; renderFacets(); };
        sec.append(vf);

        if (vendorFilter) {
          const q = vendorFilter.toLowerCase();
          for (const o of opts.vendor.filter(o => o.value.toLowerCase().includes(q)))
            addOpt(sec, 'vendor', o.value, o.count);
        } else {
          addRankedFacet(sec, 'vendor', opts.vendor);
        }
        host.append(sec);
      }
    }

    document.getElementById('search').addEventListener('input', e => { state.q = e.target.value; state.page = 1; render(); });
    document.getElementById('sort').addEventListener('change', e => { state.sort = e.target.value; state.page = 1; render(); });

    (async () => {
      readURL();
      document.getElementById('search').value = state.q;
      document.getElementById('sort').value = state.sort;
      GAMES = await (await fetch(`${BASE}/games.json`)).json();
      render();
    })();
  </script>
</Base>
